# Hermes Agent API server status integration.
# No real secrets should be committed. Copy to .env.local for local development.

# Hermes API server defaults to 127.0.0.1:8642 in current Hermes docs.
HERMES_API_BASE_URL=http://127.0.0.1:8642

# Optional. Required by authenticated Hermes endpoints such as /v1/capabilities and /v1/models.
HERMES_API_KEY=

# Set false to force mock mode even when HERMES_API_BASE_URL is present.
HERMES_UI_ENABLE_REAL_HERMES=true

# Brain Memory Gateway UI/read-only API integration.
# Web UI standalone mode: keep BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false.
# Recommended future bundle mode: set true only when a Gateway HTTP UI endpoint is running.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8765
BRAIN_MEMORY_API_KEY=
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false
