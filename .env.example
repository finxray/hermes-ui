# Hermes Agent API server status integration.
# No real secrets should be committed. Copy to .env.local for local development.

# Hermes API server defaults to 127.0.0.1:8642 in current Hermes docs.
HERMES_API_BASE_URL=http://127.0.0.1:8642

# Optional. Required by authenticated Hermes endpoints such as /v1/capabilities and /v1/models.
HERMES_API_KEY=

# Set false to force mock mode even when HERMES_API_BASE_URL is present.
HERMES_UI_ENABLE_REAL_HERMES=true

# Compatibility bridge for current Hermes session-chat metadata behavior.
# When true, the BFF also passes active project/session memory scope through
# Hermes instructions so Brain Memory MCP tool calls can include projectKey/sessionKey.
HERMES_UI_ENABLE_MEMORY_SCOPE_BRIDGE=true

# Experimental, local/dev only. Default is disabled unless explicitly true.
# Keeps production chat on /api/hermes/chat/stream.
# HERMES_UI_ENABLE_BRAIN_MEMORY_SEARCH=true

# Brain Memory Gateway UI/read-only API integration.
# Web UI standalone mode: keep BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false.
# Recommended future bundle mode: set true only when a Gateway HTTP UI endpoint is running.
# Local compose Gateway default is usually 127.0.0.1:8080.
# 127.0.0.1:8765 is the older standalone helper URL when that helper is running.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8080

# Optional UI/BFF bearer gate for Brain Memory /ui/** endpoints.
# Sent as Authorization: Bearer <value>. This is not tenant authorization.
BRAIN_MEMORY_UI_API_KEY=

# Tenant-bound Gateway memory key for /ui/memory/search and /ui/memory/{id}.
# Sent as X-Gateway-Memory-Api-Key and must authorize context.project.tenantId.
# Brain Memory live smokes need this key in the Web UI BFF process.
BRAIN_MEMORY_GATEWAY_MEMORY_API_KEY=

# Optional redacted posture flag for tenant diagnostics only.
# Set true in the Web UI process when Hermes MCP has its own Brain Memory API key.
BRAIN_MEMORY_MCP_API_KEY_SET=false

# Legacy alias kept for older local configs. Prefer the explicit variables above.
# Do not treat this as tenant authorization unless your local adapter maps it deliberately.
BRAIN_MEMORY_API_KEY=
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false
