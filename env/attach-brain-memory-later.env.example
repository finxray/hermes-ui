# Brain Memory Studio env template: attach Brain Memory later
#
# Use when you started with Web UI + Hermes and are preparing to connect a
# Brain Memory Gateway. Fill the Gateway URL and API key if needed after Brain
# Memory is installed or started.

# Required for real Hermes status/chat.
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_UI_ENABLE_REAL_HERMES=true

# Enable the project/session scope bridge before turning on real Brain Memory.
HERMES_UI_ENABLE_MEMORY_SCOPE_BRIDGE=true

# Experimental, local/dev only. Default is disabled unless explicitly true.
# Keeps production chat on /api/hermes/chat/stream.
# HERMES_UI_EXPERIMENTAL_RUNS_MODE=true

# Set this URL to your Brain Memory Gateway HTTP UI/read-only endpoint.
# Local compose Gateway is usually 127.0.0.1:8080; the older standalone helper
# commonly used 127.0.0.1:8765.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8080

# Optional UI/BFF bearer gate. Sent as Authorization: Bearer <value>.
# This is separate from tenant memory authorization.
BRAIN_MEMORY_UI_API_KEY=

# Tenant-bound key for read-only memory search. It must authorize the active
# project tenant through Gateway's GATEWAY_MEMORY_API_KEYS policy.
# Runs + Brain Memory live smokes require this in the Web UI BFF process.
BRAIN_MEMORY_GATEWAY_MEMORY_API_KEY=

# Redacted diagnostics-only flag. Set true when Hermes MCP separately has its
# own Brain Memory API key posture; do not put the key value here.
BRAIN_MEMORY_MCP_API_KEY_SET=false

# Legacy alias for older local configs. Prefer explicit variables above.
BRAIN_MEMORY_API_KEY=

# Keep false until the Gateway is actually reachable, then set true and run
# npm run studio:doctor.
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false
