# Brain Memory Studio env template: future Web UI + Brain Memory bundle
#
# Use when Hermes API server and Brain Memory Gateway HTTP UI/read-only
# endpoint are both running. This is a template only; Slice 09B does not install
# or start Brain Memory.

# Required for real Hermes status/chat.
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_UI_ENABLE_REAL_HERMES=true

# Required for real Brain Memory console status/search in bundle mode.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8765

# Optional UI/BFF bearer gate. Sent as Authorization: Bearer <value>.
# This does not authorize tenant memory reads by itself.
BRAIN_MEMORY_UI_API_KEY=

# Required for tenant-bound /ui/memory/search unless Gateway local-dev bypass
# is explicitly enabled. Sent as X-Gateway-Memory-Api-Key.
BRAIN_MEMORY_GATEWAY_MEMORY_API_KEY=

# Legacy alias for older local configs. Prefer explicit variables above.
BRAIN_MEMORY_API_KEY=
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=true
