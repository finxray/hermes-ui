# Brain Memory Studio env template: Web UI standalone without live services
#
# Use when you want to run the UI shell locally without requiring Hermes or
# Brain Memory Gateway to be running. The app will show mock/unconfigured
# service states and local browser persistence.

# Optional in this mode. Leave empty to keep Hermes in unconfigured/mock state.
HERMES_API_BASE_URL=
HERMES_API_KEY=
HERMES_UI_ENABLE_REAL_HERMES=false

# Brain Memory is optional and disabled in Web UI standalone mode.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8765
BRAIN_MEMORY_UI_API_KEY=
BRAIN_MEMORY_GATEWAY_MEMORY_API_KEY=
BRAIN_MEMORY_API_KEY=
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false
