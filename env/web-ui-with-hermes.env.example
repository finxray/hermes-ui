# Brain Memory Studio env template: Web UI standalone with Hermes
#
# Use when Hermes API server is running and you want real Hermes status/chat
# through the server-side BFF. Brain Memory remains optional and disabled.

# Required for real Hermes status/chat.
HERMES_API_BASE_URL=http://127.0.0.1:8642

# Optional in this template, but required if your Hermes API server enforces bearer auth.
HERMES_API_KEY=
HERMES_UI_ENABLE_REAL_HERMES=true

# Keep true until Hermes natively propagates request metadata.context to MCP tools.
HERMES_UI_ENABLE_MEMORY_SCOPE_BRIDGE=true

# Brain Memory is not required for Web UI + Hermes.
BRAIN_MEMORY_GATEWAY_URL=http://127.0.0.1:8765
BRAIN_MEMORY_UI_API_KEY=
BRAIN_MEMORY_GATEWAY_MEMORY_API_KEY=
BRAIN_MEMORY_API_KEY=
BRAIN_MEMORY_UI_ENABLE_REAL_GATEWAY=false
